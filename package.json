{
  "name": "sparklebot",
  "version": "1.0.0",
  "type": "module",
  "description": "A lightweight Slack bot for peer recognition. Give your teammates sparkles for being awesome.",
  "main": "src/app.js",
  "scripts": {
    "start": "node --env-file=.env src/app.js",
    "dev": "node --env-file=.env --watch src/app.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "slack",
    "bot",
    "recognition",
    "sparkles"
  ],
  "license": "MIT",
  "dependencies": {
    "@slack/bolt": "^4.1.0",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "vitest": "^3.1.1"
  }
}
