<%- include('partials/header') %>

<div class="page-header">
  <h1>💬 Channels</h1>
  <p class="subtitle"><%= currencyPlural %> by channel</p>
</div>

<% if (stats.length > 0) { %>
<% const maxCount = stats[0].count || 1; %>
<div class="card channel-list">
  <% for (const ch of stats) { %>
  <div class="channel-row">
    <span class="channel-name">#<%= ch.channel_id %></span>
    <div class="channel-bar-wrap">
      <div class="channel-bar" style="width: <%= Math.round((ch.count / maxCount) * 100) %>%"></div>
    </div>
    <span class="channel-count"><%= ch.count %></span>
  </div>
  <% } %>
</div>
<% } else { %>
<div class="card empty-state">
  <p>No channel data yet. ✨</p>
</div>
<% } %>

<%- include('partials/footer') %>
