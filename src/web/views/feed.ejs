<%- include('partials/header') %>

<div class="page-header">
  <h1>⚡ Activity <span class="badge-live">Live</span></h1>
  <p class="subtitle">Recent <%= currencyPlural %> across your workspace</p>
</div>

<div id="feed-list"
  hx-get="/feed/new?after=<%= activity.length ? activity[0].id : 0 %>"
  hx-trigger="every 10s"
  hx-swap="afterbegin">
  <% for (const item of activity) { %>
    <%- include('partials/sparkle-card', {
      giverName: item.giver_id,
      receiverName: item.receiver_name || item.receiver_id,
      reason: item.reason,
      channelName: item.channel_id,
      createdAt: item.created_at,
      isParty: false
    }) %>
  <% } %>
  <% if (activity.length === 0) { %>
  <div class="card empty-state">
    <p>No activity yet. Start sparkling your teammates! ✨</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
