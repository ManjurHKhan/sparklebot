<div class="sparkle-card <%= isParty ? 'party-card' : '' %>">
  <div class="sparkle-avatar">
    <%= isParty ? '🎉' : (giverName ? giverName.charAt(0).toUpperCase() : '?') %>
  </div>
  <div class="sparkle-content">
    <div class="sparkle-text">
      <% if (isParty) { %>
        <strong><%= giverName %></strong> threw a sparkle party!
      <% } else { %>
        <strong><%= giverName %></strong> sparkled <strong><%= receiverName %></strong>
      <% } %>
    </div>
    <% if (reason) { %>
      <div class="sparkle-reason"><em><%= reason %></em></div>
    <% } %>
    <div class="sparkle-meta">
      <span class="sparkle-channel">#<%= channelName || 'unknown' %></span>
    </div>
  </div>
  <div class="sparkle-time"><%= createdAt %></div>
</div>
