<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Sparklebot' %></title>
  <style>
    :root {
      --color-primary: <%= colorPrimary || '#6C5CE7' %>;
      --color-accent: <%= colorAccent || '#FFEAA7' %>;
    }
  </style>
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <!-- Mobile hamburger -->
  <button class="hamburger" onclick="document.querySelector('.sidebar').classList.toggle('open')" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>

  <nav class="sidebar">
    <div class="sidebar-header">
      <span class="logo"><%= emoji || '✨' %></span>
      <span class="app-name"><%= appName || 'Sparklebot' %></span>
    </div>

    <ul class="nav-links">
      <li><a href="/leaderboard" class="<%= currentPage === 'leaderboard' ? 'active' : '' %>">🏆 Leaderboard</a></li>
      <li><a href="/feed" class="<%= currentPage === 'feed' ? 'active' : '' %>">⚡ Activity</a></li>
      <li><a href="/channels" class="<%= currentPage === 'channels' ? 'active' : '' %>">💬 Channels</a></li>
      <li><a href="/me" class="<%= currentPage === 'me' ? 'active' : '' %>">✨ My Sparkles</a></li>
    </ul>

    <div class="sidebar-footer">
      <% if (user) { %>
        <div class="user-avatar"><%= user.name ? user.name.charAt(0).toUpperCase() : '?' %></div>
        <span class="user-name"><%= user.name %></span>
      <% } else { %>
        <a href="/auth/login" class="signin-link">Sign in</a>
      <% } %>
    </div>
  </nav>

  <!-- Backdrop for mobile sidebar -->
  <div class="sidebar-backdrop" onclick="document.querySelector('.sidebar').classList.remove('open')"></div>

  <main class="content">
