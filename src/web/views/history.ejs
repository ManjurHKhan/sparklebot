<%- include('partials/header') %>

<div class="page-header">
  <h1>✨ My Sparkles</h1>
  <p class="subtitle">Your recognition history</p>
</div>

<div class="stats-row">
  <div class="stat-card accent-bg">
    <div class="stat-number"><%= totalReceived %></div>
    <div class="stat-label">Received</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= totalGiven %></div>
    <div class="stat-label">Given</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= rank ? '#' + rank : '—' %></div>
    <div class="stat-label">Rank</div>
  </div>
</div>

<div class="tab-bar">
  <button class="tab-btn active"
    hx-get="/me/received"
    hx-target="#tab-content"
    hx-swap="innerHTML"
    onclick="setActiveTab(this)">
    Received
  </button>
  <button class="tab-btn"
    hx-get="/me/given"
    hx-target="#tab-content"
    hx-swap="innerHTML"
    onclick="setActiveTab(this)">
    Given
  </button>
</div>

<div id="tab-content">
  <% for (const item of received) { %>
    <%- include('partials/sparkle-card', {
      giverName: item.giver_id,
      receiverName: item.receiver_name || item.receiver_id,
      reason: item.reason,
      channelName: item.channel_id,
      createdAt: item.created_at,
      isParty: false
    }) %>
  <% } %>
  <% if (received.length === 0) { %>
  <div class="card empty-state">
    <p>No sparkles received yet. They're coming! ✨</p>
  </div>
  <% } %>
</div>

<script>
function setActiveTab(el) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}
</script>

<%- include('partials/footer') %>
